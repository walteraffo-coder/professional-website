# Contact form configuration — copy this file to `.env.local` and fill in.
# Only variables prefixed with VITE_ are exposed to the browser by Vite.

# Formspree (default integration). Create a free form at https://formspree.io,
# confirm your email, then paste your endpoint here:
VITE_FORMSPREE_ENDPOINT=https://formspree.io/f/your_form_id

# --- Optional: EmailJS alternative (see src/lib/contact.js) ---
# VITE_EMAILJS_SERVICE_ID=service_xxx
# VITE_EMAILJS_TEMPLATE_ID=template_xxx
# VITE_EMAILJS_PUBLIC_KEY=xxxxxxxx
